# === Railway: обязательно задайте в Variables ===
# Пароль входа в веб-панель /admin (без него на проде останется код по умолчанию 0397)
ADMIN_CODE=

# Ключ API intelligence.io (ответы бота в WhatsApp)
AI_API_KEY=

# WhatsApp менеджера для уведомлений о лидах (по умолчанию из consultant-knowledge.json)
# MANAGER_WHATSAPP=+34631252060

# Опционально: другая модель или endpoint
# AI_MODEL=deepseek-ai/DeepSeek-V3.2
# AI_API_URL=https://api.intelligence.io.solutions/api/v1/chat/completions
# WhatsApp-чат: 1 запрос к API (без 6 повторов). При 429 — сразу AI_FALLBACK_* если задан
# AI_CHAT_MAX_RETRIES=1
# AI_MIN_INTERVAL_MS=400
# AI_CONCURRENCY=6
# Запасной провайдер при 429 (другой ключ / OpenAI-совместимый URL)
# AI_FALLBACK_API_KEY=
# AI_FALLBACK_API_URL=https://api.openai.com/v1/chat/completions
# AI_FALLBACK_MODEL=gpt-4o-mini
# Повторы только для фоновых задач (выжимка менеджеру)
# AI_MAX_RETRIES=8

# Порт HTTP — на Railway НЕ задавайте PORT и BOT_PORT (иначе 502 на сайте)
# Локально: BOT_PORT=3001

# Сессия WhatsApp (отдельная папка от бота SellYourBrick)
# SESSION_PATH=./.wwebjs_auth_ht
# В Docker-образе из репозитория уже задано: PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_EXECUTABLE_PATH=

# Таймаут CDP Puppeteer (мс)
# PROTOCOL_TIMEOUT_MS=180000

# Веб-поиск через DuckDuckGo включён для «актуальных» вопросов; полностью отключить:
# DISABLE_WEB_SEARCH=1

# Синхронизация каталога (scripts/sync-properties.js)
# SYNC_DELAY_MS=2000
# SYNC_MAX_INDEX_PAGES=600
# SYNC_MAX_PROPERTIES=2200
